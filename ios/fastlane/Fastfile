default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    build_app(
      scheme: "Runner",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.cybage.alm" => "CybageCI"
        }
      }
    )

    upload_to_testflight(
      username: ENV["APPLE_ID"],
      app_identifier: "com.cybage.alm"
    )
  end
end
